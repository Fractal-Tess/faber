{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "lldb",
      "request": "launch",
      "name": "Remote Debug (Docker Container)",
      "program": "${workspaceFolder}/target/x86_64-unknown-linux-musl/debug/faber",
      "args": [
        "--config",
        "/faber/config/config.yaml",
        "--log-file",
        "/faber/logs/debug.log",
        "serve"
      ],
      "initCommands": [
        "platform select remote-linux",
        "platform connect connect://0.0.0.0:12345",
        "settings set target.inherit-env false"
      ],
      "cargo": {
        "args": ["build"]
      }
    }
  ]
}

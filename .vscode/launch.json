{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "lldb",
      "request": "launch",
      "name": "Remote Debug (Docker Container)",
      "program": "${workspaceFolder}/target/x86_64-unknown-linux-musl/debug/faber",
      "args": ["--config", "/faber/config/config.yaml", "serve"],
      "initCommands": [
        "platform select remote-linux",
        "platform connect connect://localhost:12345",
        "settings set target.inherit-env false"
      ],
      "preRunCommands": [
        "platform shell mkdir -p /tmp/debug",
        "platform put-file ${workspaceFolder}/target/x86_64-unknown-linux-musl/debug/faber /tmp/debug/faber",
        "platform shell chmod +x /tmp/debug/faber"
      ],
      "cargo": {
        "args": ["build"]
      }
    }
  ]
}

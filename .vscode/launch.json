{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "lldb",
      "request": "launch",
      "name": "Remote Debug (Docker Container)",
      "program": "${workspaceFolder}/target/x86_64-unknown-linux-musl/debug/faber-server",
      "args": ["serve"],
      "initCommands": [
        "platform select remote-linux",
        "platform connect connect://0.0.0.0:12345",
        "settings set target.inherit-env false"
      ],
      "env": {
        "RUST_LOG": "debug",
        "RUST_BACKTRACE": "1"
      },
      "cargo": {
        "args": ["build"]
      }
    },
    {
      "type": "lldb",
      "request": "launch",
      "name": "Remote Debug (Debug)",
      "program": "${workspaceFolder}/target/x86_64-unknown-linux-musl/debug/debug",
      "args": [],
      "initCommands": [
        "platform select remote-linux",
        "platform connect connect://0.0.0.0:12345",
        "settings set target.inherit-env false"
      ],
      "env": {
        "RUST_LOG": "debug",
        "RUST_BACKTRACE": "1"
      },
      "cargo": {
        "args": ["build"]
      }
    },

    {
      "name": "Remote Debug (GO)",
      "type": "go",
      "request": "attach",
      "mode": "remote",
      "port": 2345,
      "host": "0.0.0.0"
    }
  ]
}

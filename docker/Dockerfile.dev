FROM debian:latest

# Install g++ compiler, LLDB, and debugging tools
RUN apt update && apt install -y \
    curl \
    g++ \
    lldb \
    gdb \
    build-essential \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /faber

COPY <<EOF start.sh
#!/bin/bash

set -e

# Start lldb-server for remote debugging in the background
echo "Starting lldb-server for remote debugging..."
lldb-server platform --server --listen *:12345 
LLDB_PID=$!
echo "LLDB server started with PID: $LLDB_PID"
EOF

RUN chmod +x start.sh

ENTRYPOINT ["/faber/start.sh"]


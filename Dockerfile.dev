FROM debian:latest

# Install development dependencies
RUN apt update && apt install -y \
    curl \
    g++ \
    supervisor \
    procps \
    && rm -rf /var/lib/apt/lists/*

# Create application directory
WORKDIR /opt

# Create supervisor configuration directory
RUN mkdir -p /etc/supervisor/conf.d

# Copy supervisor configuration
COPY supervisord.conf /etc/supervisor/conf.d/faber.conf

# Create startup script
COPY start-dev.sh /opt/start-dev.sh
RUN chmod +x /opt/start-dev.sh

# Create a placeholder for the binary (will be mounted)
RUN touch /opt/faber && chmod +x /opt/faber

# Expose port
EXPOSE 3000

# Health check
HEALTHCHECK --interval=30s --timeout=10s --start-period=5s --retries=3 \
    CMD curl -f http://localhost:3000/health || exit 1

# Start supervisor
CMD ["/usr/bin/supervisord", "-c", "/etc/supervisor/supervisord.conf"] 